<navigation-bar title="房间中" back="{{true}}" color="black" background="#FFF"></navigation-bar>
<view class="page-shell">
  <ui-card>
    <view class="header">
      <text class="room-code">房间码：{{roomCode}}</text>
      <text class="status">连接状态：{{connectionStatus}}</text>
    </view>
  </ui-card>

  <ui-state-panel
    wx:if="{{pageState === 'error'}}"
    type="error"
    message="{{pageError}}"
    actionText="重试加载"
    bind:action="handleRetryLoad"
  />
  <ui-state-panel wx:if="{{pageState === 'loading'}}" type="loading" message="房间加载中..." />

  <ui-card>
    <view class="section-title">玩家列表</view>
    <view wx:for="{{players}}" wx:key="id" class="player-row">
      <view class="player-meta">
        <text class="seat">#{{item.seatNo}}</text>
        <text class="name">{{item.user.nickName}}</text>
      </view>
      <ui-button
        wx:if="{{isHost && item.user.id !== currentUserId}}"
        variant="danger"
        size="small"
        block="{{false}}"
        data-user-id="{{item.user.id}}"
        bind:tap="handleKickPlayer"
      >
        踢出
      </ui-button>
    </view>
  </ui-card>

  <ui-button wx:if="{{isHost}}" bind:tap="handleStartGame">开始游戏</ui-button>
</view>
