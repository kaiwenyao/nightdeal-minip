<navigation-bar title="房间中" back="{{true}}" color="black" background="#FFF"></navigation-bar>
<view class="page-shell">
  <ui-card>
    <view class="room-summary">
      <view>
        <text class="summary-label">房间码</text>
        <text class="room-code">{{roomCode}}</text>
      </view>
      <view class="connection-status">
        <view class="connection-dot connection-dot--{{connectionStatus}}"></view>
        <text class="status">{{connectionStatusText}}</text>
      </view>
    </view>
  </ui-card>

  <ui-state-panel
    wx:if="{{pageState === 'error'}}"
    type="error"
    message="{{pageError}}"
    actionText="重试加载"
    bind:action="handleRetryLoad"
  />
  <ui-state-panel wx:if="{{pageState === 'loading'}}" type="loading" message="房间加载中..." />

  <ui-card>
    <view class="players-heading">
      <text class="section-title">玩家列表</text>
      <text class="players-count">{{players.length}} / {{maxPlayers}}</text>
    </view>
    <view class="role-summary" wx:if="{{roleConfigSummary}}">
      <text class="summary-label">角色配置</text>
      <text class="summary-text">{{roleConfigSummary}}</text>
    </view>
    <ui-state-panel wx:if="{{players.length === 0 && pageState !== 'loading'}}" type="empty" message="暂无玩家" />
    <view wx:for="{{players}}" wx:key="id" class="player-row">
      <view class="player-meta">
        <text class="seat">#{{item.seatNo}}</text>
        <text class="name">{{item.user.nickName}}</text>
      </view>
      <ui-button
        wx:if="{{isHost && item.user.id !== currentUserId}}"
        variant="danger"
        size="small"
        block="{{false}}"
        data-user-id="{{item.user.id}}"
        bind:tap="handleKickPlayer"
      >
        踢出
      </ui-button>
    </view>
  </ui-card>

  <ui-card wx:if="{{isHost}}" class="host-actions">
    <view class="card-heading">
      <text class="section-title">房主操作</text>
    </view>
    <ui-button variant="secondary" size="small" block="{{false}}" bind:tap="handleOpenSettings" class="settings-btn">房间设置</ui-button>
    <ui-button loading="{{startingGame}}" disabled="{{startingGame}}" bind:tap="handleStartGame">开始游戏</ui-button>
  </ui-card>
</view>
