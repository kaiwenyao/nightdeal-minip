<navigation-bar title="游戏中" back="{{true}}" color="black" background="#FFF"></navigation-bar>
<view class="page-shell">
  <ui-state-panel
    wx:if="{{pageState === 'error'}}"
    type="error"
    message="{{pageError}}"
    actionText="重试加载"
    bind:action="handleRetryLoad"
  />
  <ui-state-panel wx:if="{{pageState === 'loadingRole'}}" type="loading" message="身份加载中..." />

  <ui-card>
    <view class="role-card {{roleHidden ? '' : 'revealed'}}">
      <view class="ornament-tl"></view>
      <view class="ornament-br"></view>
      <text class="label">你的身份</text>
      <text class="role-text">{{roleHidden ? '点击翻牌查看身份' : myRole}}</text>
      <text wx:if="{{!roleHidden}}" class="seat-text">座位号：#{{mySeatNo}}</text>
      <ui-button wx:if="{{roleHidden}}" bind:tap="handleRevealRole">翻牌</ui-button>
    </view>
  </ui-card>

  <ui-button variant="secondary" bind:tap="handleBackRoom">返回房间</ui-button>
</view>
