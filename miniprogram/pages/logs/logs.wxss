page {
  height: 100vh;
}

.logs-page {
  height: 100vh;
  box-sizing: border-box;
  padding-top: var(--space-6, 24rpx);
}

.log-card {
  flex: 1;
  min-height: 0;
}

.scrollarea {
  flex: 1;
  min-height: 0;
  margin-top: var(--space-4, 16rpx);
}

.log-item {
  padding: var(--space-3, 12rpx) 0;
  border-bottom: 1px solid #f3f4f6;
  color: var(--color-text-primary, #111827);
  font-size: var(--font-sm, 24rpx);
}

.log-item:last-child {
  padding-bottom: env(safe-area-inset-bottom);
  border-bottom: none;
}
