.ui-state-panel {
  border-radius: var(--radius-md, 16rpx);
  padding: var(--space-5, 20rpx) var(--space-6, 24rpx);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4, 16rpx);
  border: 2rpx solid transparent;
}

.ui-state-panel--loading {
  background: var(--color-info-bg, #edf4fb);
  border-color: rgba(59, 110, 158, 0.12);
}

.ui-state-panel--error {
  background: var(--color-danger-bg, #fceeee);
  border-color: rgba(184, 58, 58, 0.12);
}

.ui-state-panel--empty {
  background: var(--color-surface-raised, #faf9f6);
  border-color: var(--color-border, #e8e4dc);
}

.ui-state-panel--success {
  background: var(--color-success-bg, #eaf6f1);
  border-color: rgba(45, 122, 95, 0.12);
}

.ui-state-text {
  flex: 1;
  color: var(--color-text-secondary, #6b6b7b);
  font-size: var(--font-sm, 24rpx);
  line-height: 1.5;
}

.ui-state-panel--error .ui-state-text {
  color: var(--color-danger, #b83a3a);
  font-weight: var(--font-medium, 500);
}

.ui-state-panel--loading .ui-state-text {
  color: var(--color-info, #3b6e9e);
}

.ui-state-panel--success .ui-state-text {
  color: var(--color-success, #2d7a5f);
}
