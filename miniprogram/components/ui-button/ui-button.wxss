.ui-button {
  border-radius: var(--radius-sm, 12rpx);
  font-size: var(--font-base, 28rpx);
}

.ui-button::after {
  border: none;
}

.ui-button--block {
  width: 100%;
}

.ui-button--primary {
  background: var(--color-accent, #111827);
  color: #ffffff;
}

.ui-button--secondary {
  background: var(--color-surface, #ffffff);
  color: var(--color-text-primary, #111827);
  border: 1px solid var(--color-border, #e5e7eb);
}

.ui-button--danger {
  background: var(--color-danger-bg, #fee2e2);
  color: var(--color-danger, #b91c1c);
}

.ui-button--small {
  min-height: 56rpx;
  line-height: 56rpx;
  font-size: var(--font-sm, 24rpx);
  padding: 0 var(--space-4, 16rpx);
}

.ui-button--normal {
  min-height: 78rpx;
  line-height: 78rpx;
}
